---
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Features from '../components/sections/Features.astro';
import Services from '../components/sections/Services.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTA from '../components/sections/CTA.astro';
import Footer from '../components/sections/Footer.astro';
---
<Layout
  title="GO Essence — Estética y Spa"
  description="En GO Essence combinamos ciencia, estética e innovación para lograr resultados visibles y duraderos. Rejuvenecimiento facial, protocolos avanzados y tratamientos corporales en Barranquilla."
>
  <Header />
  <main>
    <Hero />
    <About />
    <Features />
    <Services />
    <Testimonials />
    <CTA />
  </main>
  <Footer />
</Layout>
