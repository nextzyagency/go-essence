---
// ContactInfo.astro
---

<section class="py-24 bg-white border-t" style="border-color:#F0E0C7;">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="grid md:grid-cols-2 gap-12 text-center info-cards">
      <div class="flex flex-col items-center p-8">
        <div
          class="w-16 h-16 rounded-full flex items-center justify-center bg-[#FDFBF7] border border-[#F0E0C7] mb-6"
        >
          <svg
            fill="none"
            stroke="#AF7127"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="28"
            height="28"
            ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"
            ></path><circle cx="12" cy="10" r="3"></circle></svg
          >
        </div>
        <h3 class="text-xl mb-3 font-semibold" style="color:#6B2F1E;">
          Visítanos
        </h3>
        <p class="font-light" style="color:#934829;">
          Calle 84 # 51B - 73<br />Centro Médico, Barranquilla, Colombia
        </p>
      </div>

      <div class="flex flex-col items-center p-8">
        <div
          class="w-16 h-16 rounded-full flex items-center justify-center bg-[#FDFBF7] border border-[#F0E0C7] mb-6"
        >
          <svg
            fill="none"
            stroke="#AF7127"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            viewBox="0 0 24 24"
            width="28"
            height="28"
            ><path
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
            ></path></svg
          >
        </div>
        <h3 class="text-xl mb-3 font-semibold" style="color:#6B2F1E;">
          Llámanos
        </h3>
        <p class="font-light" style="color:#934829;">
          +57 314 7138877<br />Lunes a Sábado: 8:00 AM - 7:00 PM
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".info-cards > div", {
    scrollTrigger: { trigger: ".info-cards", start: "top 85%" },
    y: 30,
    duration: 0.8,
    stagger: 0.2,
    ease: "power2.out",
  });
</script>
