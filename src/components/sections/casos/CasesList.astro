---
// CasesList.astro
const instagramPosts = [
  "https://www.instagram.com/p/DW1mhcOERJQ/embed",
  "https://www.instagram.com/p/DWzEnbUkXzu/embed",
  "https://www.instagram.com/p/DWJ6s07AO7T/embed"
];
---
<section class="py-24 bg-[#F0E0C7]">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <h2 class="text-3xl md:text-5xl mb-16 text-center" style="color:#6B2F1E; font-family:'Cormorant Garamond',serif; font-weight:600;">
      Testimonios y Tratamientos
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 case-list">
      {instagramPosts.map((url, i) => (
        <div class="bg-white p-4 shadow-sm border border-[#DFCEC1] flex justify-center hover:-translate-y-2 transition-transform duration-300">
          <iframe 
            src={url} 
            width="100%" 
            height="550" 
            frameborder="0" 
            scrolling="no" 
            allowtransparency="true"
            class="w-full h-[550px]"
            title={`Testimonio en video ${i + 1}`}
          ></iframe>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.case-list > div', {
    scrollTrigger: { trigger: '.case-list', start: 'top 85%' },
    y: 30, opacity: 0, duration: 0.8, stagger: 0.15, ease: 'power2.out'
  });
</script>
