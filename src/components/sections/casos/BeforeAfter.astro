---
// BeforeAfter.astro
import { Image } from 'astro:assets';
import antesImg from '../../../assets/imagenes/servicios/El problema.JPG';
import despuesImg from '../../../assets/imagenes/servicios/limpieza.jpg';
---
<section class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center">
    <h2 class="text-3xl md:text-5xl mb-12" style="color:#6B2F1E; font-family:'Cormorant Garamond',serif; font-weight:600;">
      Evidencia Visual
    </h2>
    
    <div class="mb-10 text-center">
      <h3 class="text-2xl font-medium" style="color:#6B2F1E;">Control de Manchas (Melasma)</h3>
      <p class="text-base mt-2 text-[#934829] max-w-2xl mx-auto">Peeling despigmentante + Tratamiento en casa (8 semanas)</p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 lg:gap-8 before-after-grid max-w-5xl mx-auto">
      <!-- Tarjeta Antes (Izquierda) -->
      <div class="relative overflow-hidden border border-[#DFCEC1] shadow-sm">
        <div class="relative h-[400px] md:h-[500px]">
          <Image src={antesImg} alt="Antes del tratamiento" class="w-full h-full object-cover grayscale opacity-90" />
          <div class="absolute top-4 left-4 bg-black/70 text-white text-xs px-4 py-2 uppercase tracking-widest font-medium">
            Antes
          </div>
        </div>
      </div>

      <!-- Tarjeta Después (Derecha) -->
      <div class="relative overflow-hidden border border-[#DFCEC1] shadow-sm">
        <div class="relative h-[400px] md:h-[500px]">
          <Image src={despuesImg} alt="Después del tratamiento" class="w-full h-full object-cover" />
          <div class="absolute top-4 right-4 bg-[#AF7127] text-white text-xs px-4 py-2 uppercase tracking-widest font-medium shadow-md">
            Después
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.before-after-grid > div', {
    scrollTrigger: { trigger: '.before-after-grid', start: 'top 85%' },
    y: 40, opacity: 0, duration: 0.8, stagger: 0.2, ease: 'power2.out'
  });
</script>
