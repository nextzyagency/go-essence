---
// Testimonials.astro
const testimonials = [
  {
    quote: '"La tecnología que usan es de otro nivel. Me hice el rejuvenecimiento facial y los cambios en la textura de mi piel son impresionantes desde la primera sesión."',
    name: 'Elena V.',
    treatment: 'Rejuvenecimiento Facial',
  },
  {
    quote: '"Lo que más me gusta es el trato. No te sientes como un número más, analizan tu piel con cuidado y te explican cada paso del protocolo personalizado para el acné."',
    name: 'Carla M.',
    treatment: 'Protocolo Anti-Acné',
  },
  {
    quote: '"Había probado muchos peeling pero ninguno tan efectivo como el de GO Essence. Mis manchas desaparecieron y mi piel ahora brilla de verdad."',
    name: 'Sandra R.',
    treatment: 'Peeling Químico',
  },
];
---
<section id="testimonios" class="section-pad overflow-hidden" style="background:#6B2F1E;">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-14 lg:flex lg:items-end lg:justify-between gap-10">
      <div>
        <p class="section-label" style="color:#AF7127;" id="test-label">Experiencias</p>
        <h2 class="text-4xl lg:text-5xl xl:text-6xl" style="color:#F0E0C7; font-family:var(--font-title); font-weight:700;" id="test-title">
          Experiencias GO Essence.
        </h2>
        <p class="mt-3 text-base" style="color:#F0E0C7; opacity:0.7; max-width:460px;">
          Lo que dicen nuestras pacientes después de pasar por el laboratorio de la esencia.
        </p>
      </div>

      <!-- Star row -->
      <div class="mt-6 lg:mt-0 flex items-center gap-1">
        {Array(5).fill(null).map(() => (
          <svg width="18" height="18" viewBox="0 0 18 18">
            <polygon points="9,2 11,7 17,7 12,11 14,17 9,13 4,17 6,11 1,7 7,7" fill="#AF7127"/>
          </svg>
        ))}
        <span class="ml-3 text-sm" style="color:#F0E0C7; opacity:0.7;">5.0 · 120+ pacientes</span>
      </div>
    </div>

    <!-- Testimonial cards track -->
    <div id="test-track" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {testimonials.map((t, i) => (
        <div class="testimonial-card p-8" style="border: 1px solid rgba(240,224,199,0.2);">
          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {Array(5).fill(null).map(() => (
              <svg width="14" height="14" viewBox="0 0 18 18">
                <polygon points="9,2 11,7 17,7 12,11 14,17 9,13 4,17 6,11 1,7 7,7" fill="#AF7127"/>
              </svg>
            ))}
          </div>
          <p class="text-base lg:text-lg leading-relaxed mb-8" style="color:#F0E0C7; font-style:italic; font-weight:300;">
            {t.quote}
          </p>
          <div style="border-top: 1px solid rgba(240,224,199,0.2);" class="pt-5">
            <p class="text-sm font-medium" style="color:#F0E0C7;">{t.name}</p>
            <p class="text-xs mt-1" style="color:#AF7127; letter-spacing:0.1em; text-transform:uppercase;">{t.treatment}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('#test-label, #test-title', {
    y: 22, opacity: 0, duration: 1, stagger: 0.12, ease: 'power3.out',
    scrollTrigger: { trigger: '#testimonios', start: 'top 75%' },
  });

  gsap.from('.testimonial-card', {
    y: 30, opacity: 0, duration: 0.9, stagger: 0.18, ease: 'power3.out',
    scrollTrigger: { trigger: '#testimonios', start: 'top 65%' },
  });

  // Subtle horizontal parallax on scroll
  gsap.to('#test-track', {
    x: -40,
    ease: 'none',
    scrollTrigger: {
      trigger: '#testimonios',
      start: 'top bottom',
      end: 'bottom top',
      scrub: 1.5,
    },
  });
</script>
