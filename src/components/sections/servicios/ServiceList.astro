---
// ServiceList.astro
import { Image } from 'astro:assets';
import { servicesData } from '../../../data/servicesData.js';
---
<section class="py-24 bg-white" id="catalogo">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    <div class="text-center mb-16 max-w-2xl mx-auto slist-header">
      <p class="section-label mb-4">Nuestro Catálogo Estético</p>
      <h2 class="text-4xl lg:text-5xl mb-4 leading-tight" style="color:#6B2F1E; font-family:'Cormorant Garamond',serif; font-weight:700;">
        Procedimientos que Realzan tu Imagen
      </h2>
      <p class="text-lg" style="color:#934829; font-weight:300;">
        Cada protocolo es llevado a cabo con los más altos estándares clínicos y productos de primera línea.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 slist-cards">
      {servicesData.map((s) => (
        <a href={`/servicios/${s.slug}`} class="group flex flex-col border overflow-hidden hover:-translate-y-2 transition-transform duration-300 bg-[#FDFBF7]" style="border-color:#DFCEC1;">
          <div class="relative w-full h-56 overflow-hidden">
            <Image src={s.image} alt={s.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="p-8 flex flex-col flex-1 gap-4">
            <div class="w-12 h-12 bg-[#AF7127]/20 rounded-full flex items-center justify-center shrink-0">
              <svg fill="#6B2F1E" viewBox="0 0 24 24" width="24" height="24" set:html={s.icon} />
            </div>
            <h3 class="text-xl" style="color:#6B2F1E; font-family:'Cormorant Garamond',serif; font-weight:600;">{s.title}</h3>
            <p class="text-sm leading-relaxed" style="color:#934829; font-weight:300;">{s.shortDesc}</p>
            <div class="mt-auto pt-4 text-xs tracking-widest font-semibold uppercase group-hover:underline transition-all" style="color:#AF7127;">
              Ver Detalles de {s.title} &rarr;
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.from('.slist-header > *', {
    scrollTrigger: { trigger: '.slist-header', start: 'top 85%' },
    y: 20, opacity: 0, duration: 0.8, stagger: 0.15, ease: 'power2.out'
  });
  
  gsap.from('.slist-cards > a', {
    scrollTrigger: { trigger: '.slist-cards', start: 'top 80%' },
    y: 30, opacity: 0, duration: 0.9, stagger: 0.15, ease: 'power2.out'
  });
</script>
